# Git line ending normalization
* text=auto

# Shell scripts should use LF
*.sh text eol=lf
*.bash text eol=lf

# Python files should use LF
*.py text eol=lf

# Windows batch files should use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Markdown files should use LF
*.md text eol=lf

# JSON/YAML should use LF
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Binary files
*.png binary
*.jpg binary
*.gif binary
*.pdf binary
